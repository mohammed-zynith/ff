# Backend environment variables example
# Copy to .env and fill values before running

PORT=3000
MONGODB_URI=mongodb://localhost:27017/dbname
JWT_SECRET=your_jwt_secret
EMAIL_USER=your-email@example.com
EMAIL_PASS=your-email-password
EMAIL_FROM=Zynith IT Solutions <no-reply@example.com>
FRONTEND_URL=http://localhost:5173

# Resend API key (set this in production as a secret)
RESEND_API_KEY=re_XXXXXXXXXXXXXXXXXXXXXXXX

# Optional: address to send a test email to when running `testEmailConfig`
TEST_EMAIL_TO=your-test-email@example.com
